# ══════════════════════════════════════════════════════════
# AI Trading Assistant - Environment Variables
# Copy file ini ke .env dan isi API keys kamu
# ══════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────
# Default: Google Gemini (GRATIS - 15 RPM, 1500 req/hari)
# Cara dapat API key: https://aistudio.google.com/apikey
TRADING_AGENTS_LLM_PROVIDER=google
TRADING_AGENTS_DEEP_THINK_LLM=gemini-2.5-flash
TRADING_AGENTS_QUICK_THINK_LLM=gemini-2.5-flash
TRADING_AGENTS_TEMPERATURE=0.1

# Google Gemini API (GRATIS)
# 1. Buka https://aistudio.google.com/apikey
# 2. Login pakai akun Google kamu
# 3. Klik "Create API Key"
# 4. Copy API key-nya dan paste di bawah
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ── Alternatif LLM (opsional) ────────────────────────────
# DeepSeek (murah ~$0.14/M tokens)
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Telegram ──────────────────────────────────────────────
# Cara setup:
# 1. Buka Telegram, cari @BotFather
# 2. Kirim /newbot, ikuti instruksi
# 3. Copy token yang diberikan
# 4. Kirim pesan ke bot kamu, lalu buka:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Cari "chat":{"id": XXXXXXX} - itu Chat ID kamu
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Discord ───────────────────────────────────────────────
# Cara setup:
# 1. Buka Discord > Server Settings > Integrations > Webhooks
# 2. Klik "New Webhook", pilih channel
# 3. Copy Webhook URL
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ── Email (Gmail) ────────────────────────────────────────
# Cara setup:
# 1. Buka https://myaccount.google.com/apppasswords
# 2. Generate App Password untuk "Mail"
# 3. Gunakan App Password (bukan password Gmail biasa)
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECEIVER=your_email@gmail.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
