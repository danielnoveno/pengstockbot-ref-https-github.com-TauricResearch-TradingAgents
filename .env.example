# ══════════════════════════════════════════════════════════
# AI Trading Assistant - Environment Variables
# Copy file ini ke .env dan isi API keys kamu
# ══════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────
TRADING_AGENTS_LLM_PROVIDER=google
TRADING_AGENTS_DEEP_THINK_LLM=gemini-2.5-flash
TRADING_AGENTS_QUICK_THINK_LLM=gemini-2.5-flash
TRADING_AGENTS_TEMPERATURE=0.1
OUTPUT_LANGUAGE=Bahasa Indonesia

# ── API Keys ──────────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_api_key_here
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ── Watchlist ─────────────────────────────────────────────
# Comma-separated tickers (or use WATCHLIST_FILE for JSON)
# WATCHLIST=AAPL,MSFT,GOOGL,BTC-USD,ETH-USD,BBCA.JK
# WATCHLIST_FILE=path/to/watchlist.json

# ── Market Indices (Yahoo Finance tickers) ────────────────
IDX_SP500=^GSPC
IDX_NASDAQ=^IXIC
IDX_DOW=^DJI
IDX_IHSG=^JKSE
IDX_NIKKEI=^N225
IDX_HANGSENG=^HSI
IDX_BTC=BTC-USD
IDX_ETH=ETH-USD

# ── Scanner Settings ──────────────────────────────────────
PRICE_CHECK_INTERVAL=60
SCANNER_INTERVAL=300
DEEP_ANALYSIS_INTERVAL=1800

# ── Alert Thresholds ──────────────────────────────────────
PRICE_CHANGE_ALERT=3.0
PRICE_CRITICAL_ALERT=5.0
VOLUME_SPIKE_MULTIPLIER=2.0
HUGE_VOLUME_MULTIPLIER=5.0

# ── Display Limits ────────────────────────────────────────
MAX_TICKERS_SCAN=30
MAX_NEWS_ITEMS=5
MAX_ALERTS_DISPLAY=20
MAX_TRENDING_DISPLAY=10

# ── Schedule Times (HH:MM) ───────────────────────────────
MORNING_BRIEFING_TIME=07:30
EVENING_SUMMARY_TIME=16:30

# ── Data Periods ──────────────────────────────────────────
DATA_PERIOD_SHORT=2d
DATA_PERIOD_MEDIUM=1mo
DATA_PERIOD_LONG=3mo

# ── Sentiment Keywords (JSON file) ────────────────────────
# SENTIMENT_KEYWORDS_FILE=path/to/sentiment.json

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord ───────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_WEBHOOK_URL=

# ── Email (Gmail) ────────────────────────────────────────
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_RECEIVER=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8088
DASHBOARD_REFRESH_INTERVAL=15

# ── Database ──────────────────────────────────────────────
DATABASE_NAME=trading_assistant.db
